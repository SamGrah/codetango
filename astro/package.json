{
  "name": "astro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "charts": "node scripts/build-charts.mjs",
    "predev": "node scripts/build-charts.mjs && node scripts/dev-search.mjs",
    "dev": "astro dev",
    "prebuild": "node scripts/build-charts.mjs && node -e \"require('fs').rmSync('public/pagefind',{recursive:true,force:true})\"",
    "build": "astro build",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:watch": "vitest",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/open-sans": "^5.2.7",
    "astro": "^7.0.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.3.0",
    "node-html-parser": "^9.0.0",
    "pagefind": "^1.5.2",
    "sanitize-html": "^2.17.5",
    "typescript": "^6.0.3",
    "vega": "^6.2.0",
    "vega-lite": "^6.4.3",
    "vitest": "^4.1.10"
  }
}
