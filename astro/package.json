{
  "name": "astro",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "charts": "node scripts/build-charts.mjs",
    "predev": "node scripts/build-charts.mjs && node scripts/dev-search.mjs",
    "dev": "astro dev",
    "prebuild": "node scripts/build-charts.mjs && node -e \"fs.rmSync('public/pagefind',{recursive:true,force:true})\"",
    "build": "astro build",
    "postbuild": "pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/open-sans": "^5.2.7",
    "astro": "^7.0.6"
  },
  "devDependencies": {
    "pagefind": "^1.5.2",
    "vega": "^6.2.0",
    "vega-lite": "^6.4.3"
  }
}
