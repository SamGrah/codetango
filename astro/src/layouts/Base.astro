---
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/open-sans';
import '@fontsource-variable/open-sans/wght-italic.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
}

const {
  title,
  description = 'A technical blog about agentic AI development and operations.',
  ogType = 'website',
} = Astro.props;

const pageTitle = title ? `${title} · codeTango` : 'codeTango';
const canonical = new URL(Astro.url.pathname, Astro.site);
const { pathname } = Astro.url;
const postsActive = pathname === '/' || pathname.startsWith('/blog/');
const aboutActive = pathname.startsWith('/about');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="codeTango"
      href={new URL('rss.xml', Astro.site)}
    />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0a1a1e" />
    <!-- Resolve theme before first paint: stored preference wins, else system. -->
    <script is:inline>
      (() => {
        const mq = window.matchMedia('(prefers-color-scheme: dark)');
        const apply = () => {
          const stored = localStorage.getItem('theme');
          document.documentElement.dataset.theme =
            stored === 'light' || stored === 'dark' ? stored : mq.matches ? 'dark' : 'light';
        };
        apply();
        mq.addEventListener('change', () => {
          if (!localStorage.getItem('theme')) apply();
        });
        // ClientRouter swaps in the new document's <html> attributes, which wipes
        // data-theme (server HTML never has it). Re-apply after every swap so the
        // chosen theme persists across client-side navigations.
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
    <ClientRouter />
    <!-- Pagefind Component UI (search modal) — small idle assets on every page so the
         header search works site-wide; the index itself lazy-loads on first keystroke.
         404s harmlessly under `npm run dev` (index is built post-build). -->
    <link rel="stylesheet" href="/pagefind/pagefind-component-ui.css" />
    <script is:inline type="module" src="/pagefind/pagefind-component-ui.js"></script>
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <nav class="container site-nav" aria-label="Site">
        <a class="wordmark" href="/"><em>code</em><span>Tango</span></a>
        <a class="nav-link" href="/" aria-current={postsActive ? 'page' : undefined}>Posts</a>
        <a class="nav-link" href="/about/" aria-current={aboutActive ? 'page' : undefined}>About</a>
        <button id="search-open" class="icon-link" aria-label="Search" title="Search (⌘K or /)">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="m20 20-3.8-3.8"></path>
          </svg>
        </button>
        <button id="theme-toggle" aria-label="Toggle color theme" title="Toggle color theme">
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
          </svg>
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
          </svg>
        </button>
      </nav>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <span>© {new Date().getFullYear()} Sam Graham</span>
        <span class="footer-links">
          <a href="/rss.xml" aria-label="RSS feed">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20 5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44M4 10.1A9.9 9.9 0 0 1 13.9 20h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/></svg>
          </a>
          <a href="https://github.com/SamGrah" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/samgr/" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://www.google.com/search?q=silicon+valley+hbo" title="Middle-out compression" aria-label="Pied Piper">
            <svg class="pp-hat" viewBox="0 0 640 512" fill="currentColor" aria-hidden="true"><path d="M640 24.9c-80.8 53.6-89.4 92.5-96.4 104.4-6.7 12.2-11.7 60.3-23.3 83.6-11.7 23.6-54.2 42.2-66.1 50-11.7 7.8-28.3 38.1-41.9 64.2-108.1-4.4-167.4 38.8-259.2 93.6 29.4-9.7 43.3-16.7 43.3-16.7 94.2-36 139.3-68.3 281.1-49.2 1.1 0 1.9 .6 2.8 .8 3.9 2.2 5.3 6.9 3.1 10.8l-53.9 95.8c-2.5 4.7-7.8 7.2-13.1 6.1-126.8-23.8-226.9 17.3-318.9 18.6-73.4 1.1-97.5-33.5-97.5-35.1 0-1.1 .6-1.7 1.7-1.7 0 0 38.3 0 103.1-15.3 73.6-140.3 139.2-189.4 210.6-189.4 0 0 71.7 0 90.6 61.9 22.8-39.7 28.3-49.2 28.3-49.2 5.3-9.4 35-77.2 86.4-141.4 51.5-64 90.4-79.9 119.3-91.8z"/></svg>
          </a>
        </span>
      </div>
    </footer>

    <!-- Single site-wide search field (Material-style): header icon or ⌘K opens the
         Pagefind modal with live-as-you-type results. reset-on-close clears state. -->
    <pagefind-modal reset-on-close></pagefind-modal>

    <!-- Delegated on document (which survives ClientRouter's body swaps) so these
         keep working after client-side navigations. Note: swaps DO wipe <html>'s
         data-theme attribute — the head script restores it on astro:after-swap. -->
    <script is:inline>
      document.addEventListener('click', (e) => {
        if (e.target.closest('#theme-toggle')) {
          const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          localStorage.setItem('theme', next);
        } else if (e.target.closest('#search-open')) {
          document.querySelector('pagefind-modal')?.open();
        }
      });
      // mod+K or "/" opens search from anywhere. Both are suppressed while the user
      // is typing in a field, so they behave normally there (incl. typing "/").
      document.addEventListener('keydown', (e) => {
        const t = e.target;
        if (t && (t.tagName === 'INPUT' || t.tagName === 'TEXTAREA' || t.isContentEditable)) return;
        const mod = /Mac/.test(navigator.platform) ? e.metaKey : e.ctrlKey;
        const isModK = mod && e.key.toLowerCase() === 'k';
        const isSlash = e.key === '/' && !e.metaKey && !e.ctrlKey && !e.altKey;
        if (!isModK && !isSlash) return;
        e.preventDefault();
        document.querySelector('pagefind-modal')?.open();
      });
    </script>
  </body>
</html>
