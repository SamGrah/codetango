---
import { ClientRouter } from 'astro:transitions';
import '@fontsource-variable/open-sans';
import '@fontsource-variable/open-sans/wght-italic.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
}

const {
  title,
  description = 'A technical blog about agentic AI development and operations.',
  ogType = 'website',
} = Astro.props;

const pageTitle = title ? `${title} · codeTango` : 'codeTango';
const canonical = new URL(Astro.url.pathname, Astro.site);
const { pathname } = Astro.url;
const postsActive = pathname === '/' || pathname.startsWith('/blog/');
const aboutActive = pathname.startsWith('/about');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="codeTango"
      href={new URL('rss.xml', Astro.site)}
    />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0a1a1e" />
    <!-- Resolve theme before first paint: stored preference wins, else system. -->
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const mq = window.matchMedia('(prefers-color-scheme: dark)');
        const apply = (t) => (document.documentElement.dataset.theme = t);
        apply(stored === 'light' || stored === 'dark' ? stored : mq.matches ? 'dark' : 'light');
        mq.addEventListener('change', (e) => {
          if (!localStorage.getItem('theme')) apply(e.matches ? 'dark' : 'light');
        });
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <header class="site-header">
      <nav class="container site-nav" aria-label="Site">
        <a class="wordmark" href="/"><em>code</em><span>Tango</span></a>
        <a class="nav-link" href="/" aria-current={postsActive ? 'page' : undefined}>Posts</a>
        <a class="nav-link" href="/about/" aria-current={aboutActive ? 'page' : undefined}>About</a>
        <button id="theme-toggle" aria-label="Toggle color theme" title="Toggle color theme">
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
          </svg>
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
          </svg>
        </button>
      </nav>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <span>© {new Date().getFullYear()} Sam Graham</span>
        <span class="footer-links">
          <a href="/rss.xml">RSS</a>
          <a href="https://github.com/SamGrah">GitHub</a>
          <a href="https://www.linkedin.com/in/samgr/">LinkedIn</a>
          <a href="https://www.google.com/search?q=silicon+valley+hbo" title="Mean jerk time calculator inside">Pied Piper</a>
        </span>
      </div>
    </footer>

    <!-- Delegated on document (which survives ClientRouter's body swaps) so the
         toggle keeps working after client-side navigations. The <html> element
         also persists across swaps, so data-theme carries over with no flash. -->
    <script is:inline>
      document.addEventListener('click', (e) => {
        if (!e.target.closest('#theme-toggle')) return;
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>
